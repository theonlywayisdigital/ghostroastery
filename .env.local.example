# ===========================================
# Roastery Platform - Environment Variables
# ===========================================
# Copy this file to .env.local and fill in your values
# NEVER commit .env.local to version control

# -------------------------------------------
# SANITY CMS
# -------------------------------------------
# Create a project at https://sanity.io/manage
NEXT_PUBLIC_SANITY_PROJECT_ID=your_project_id
NEXT_PUBLIC_SANITY_DATASET=production

# -------------------------------------------
# SUPABASE
# -------------------------------------------
# Get these from your Supabase project settings > API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# -------------------------------------------
# STRIPE
# -------------------------------------------
# Get these from https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_your_secret_key
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your_publishable_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# -------------------------------------------
# RESEND (Email)
# -------------------------------------------
# Get this from https://resend.com/api-keys
RESEND_API_KEY=re_your_api_key

# -------------------------------------------
# SANITY API TOKEN (for write operations / label uploads)
# -------------------------------------------
# Create at https://www.sanity.io/manage > API > Tokens
SANITY_API_TOKEN=your_token

# -------------------------------------------
# SITE URL (for Stripe redirect URLs)
# -------------------------------------------
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# -------------------------------------------
# ADMIN EMAIL (for order notifications)
# -------------------------------------------
ADMIN_EMAIL=admin@roasteryplatform.com

# -------------------------------------------
# ORDER STATUS WEBHOOK
# -------------------------------------------
# Secret for authenticating order status update webhooks
ORDER_STATUS_WEBHOOK_SECRET=your_secret

# -------------------------------------------
# GOOGLE ANALYTICS
# -------------------------------------------
# Get this from Google Analytics 4 property settings
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX
